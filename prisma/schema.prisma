generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id Int @id @default(autoincrement())
  firstName String
  lastName String
  email String @unique
  password String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum WoodType {
  softwood
  exotic_wood
  noble_and_hardwoods
}

enum Hardness {
  tender
  medium_hard
  hard
}

model Wood {
  id Int @id @default(autoincrement())
  name String @unique
  type WoodType
  hardness Hardness
  image String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}